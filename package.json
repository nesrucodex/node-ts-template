{
  "name": "node-ts-template",
  "version": "1.0.0",
  "main": "./dist/server.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node ./dist/server.js",
    "dev": "cross-env NODE_ENV=development nodemon",
    "build": "npm run clean && tsc",
    "clean": "rimraf ./dist"
  },
  "author": "Nesredin Getahun",
  "license": "ISC",
  "description": "A modern Node.js TypeScript template with essential configurations for building RESTful APIs. Includes support for environment variable management, logging, and development tooling.",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.8.6",
    "cross-env": "^7.0.3",
    "rimraf": "^6.0.1"
  }
}
